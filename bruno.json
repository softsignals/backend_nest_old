{
  "version": "1",
  "name": "SoftSignals Backend API",
  "type": "collection",
  "ignore": [
    "node_modules",
    "dist",
    "coverage",
    ".git"
  ],
  "x-load-test": {
    "baseUrl": "http://localhost:3000/api/v1",
    "auth": {
      "loginPath": "/auth/login",
      "bodyTemplate": {
        "email": "admin@example.com",
        "password": "ChangeMe123!",
        "deviceId": "bruno-load-device"
      },
      "extract": {
        "accessToken": "$.accessToken"
      }
    },
    "scenarios": [
      {
        "name": "timbrature-burst",
        "description": "Invio concorrente di molte timbrature + polling stato job",
        "requestPath": "/timbrature",
        "requestMethod": "POST",
        "requestHeaders": {
          "Authorization": "Bearer {{accessToken}}",
          "Content-Type": "application/json",
          "Idempotency-Key": "{{uuid}}"
        },
        "requestBodyTemplate": {
          "userId": "{{userId}}",
          "commessaId": "{{commessaId}}",
          "tipo": "{{tipo}}",
          "deviceTimestamp": "{{isoNow}}",
          "origine": "ONLINE",
          "note": "load-test"
        },
        "concurrency": 50,
        "totalRequests": 1000,
        "typesCycle": [
          "IN",
          "OUT"
        ],
        "jobStatus": {
          "enabled": true,
          "pathTemplate": "/timbrature/jobs/{{jobId}}",
          "maxPollAttempts": 10,
          "pollIntervalMs": 250
        }
      }
    ],
    "variables": {
      "userId": "00000000-0000-0000-0000-000000000001",
      "commessaId": "00000000-0000-0000-0000-000000000101"
    },
    "runnerHints": {
      "recommendedParallel": 50,
      "recommendedIterations": 1000,
      "exampleCommand": "bru run --env local --parallel 50 --iteration-count 1000"
    }
  }
}
