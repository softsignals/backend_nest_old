{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/api-gateway-bff",
  "sourceRoot": "apps/api-gateway-bff/src",
  "compilerOptions": {
    "deleteOutDir": true
  },
  "projects": {
    "api-gateway-bff": {
      "type": "application",
      "root": "apps/api-gateway-bff",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway-bff/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway-bff/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "timbrature-service": {
      "type": "application",
      "root": "apps/timbrature-service",
      "entryFile": "main",
      "sourceRoot": "apps/timbrature-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/timbrature-service/tsconfig.app.json"
      }
    }
  }
}
