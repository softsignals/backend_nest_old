# Shared
DATABASE_URL=postgres://postgres:postgres@localhost:5432/softsignals

# Gateway
PORT=3000
GATEWAY_CORS_ORIGINS=http://localhost:8081,http://localhost:19006
AUTH_SERVICE_URL=http://localhost:3001
TIMBRATURE_SERVICE_URL=http://localhost:3002

# Auth service
JWT_SECRET=replace_with_strong_secret_value
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=7
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=replace_with_strong_password
AUTH_ADMIN_CODICE_DIPENDENTE=ADMIN-0001
AUTH_ADMIN_NOME=Admin
AUTH_ADMIN_COGNOME=User
AUTH_ADMIN_DATA_ASSUNZIONE=2000-01-01

# Timbrature service
REDIS_HOST=localhost
REDIS_PORT=6379
COMMESSE_QR_REGEN_PASSWORD=replace_with_qr_regen_password
